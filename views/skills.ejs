<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
 <%- include('./partials/nav') %>
</head>
<body>
   
    <% skills.forEach(function(item){ %>
    <div class="cards-container"> 
    <h2>Skill</h2>
    <%=item.name %>
    <h2>Category</h2>
    <%=item.category %>
    <h2>Level</h2>
    <%=item.level %>
    <h2>Description</h2>
    <%=item.description %>
    </div>
    <% }) %>

    
</body>
</html>